  "about": {
    "title": "About El-Najah",
    "subtitle": "We build tools that help students learn deliberately and prove it.",
    "mission": {
      "title": "Our mission",
      "body": "Most learning platforms optimize for time-on-site. We optimize for actual mastery. Every feature in El-Najah exists to answer one question: is the student getting better, and where should they focus next?"
    },
    "values": {
      "title": "What we believe",
      "items": {
        "focus": {
          "title": "Focus over features",
          "body": "A small set of well-designed tools beats a hundred half-built ones."
        },
        "evidence": {
          "title": "Evidence over opinion",
          "body": "Progress tracking, not vibes. If you can't measure it, we don't ship it."
        },
        "respect": {
          "title": "Respect for the student",
          "body": "No manipulative notifications, no engagement traps. Your time is yours."
        }
      }
    }
  },
